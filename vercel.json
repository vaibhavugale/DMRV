{
  "version": 2,
  "functions": {
    "apps/api-service/src/index.ts": {
      "runtime": "vercel-node@latest"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "apps/api-service/src/index.ts"
    },
    {
      "source": "/health",
      "destination": "apps/api-service/src/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "apps/api-service/src/index.ts"
    }
  ]
}
